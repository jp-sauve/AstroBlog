---
import BaseLayout from "../layouts/BaseLayout.astro";
const pageTitle = "About";

const identity = {
    firstName: "JP",
    country: "Canada",
    occupation: "Senior Software Engineer",
    hobbies: ["cycling", "bikepacking", "learning"],
};

const skills = ["HTML", "CSS", "JavaScript", "React", "Astro", "Writing Docs"];
const happy = true;
const finished = true;
const goal = 3;
---

<BaseLayout pageTitle={pageTitle} current="about">
    <section class="card">
        <p class="eyebrow">About</p>
        <p class="lede">
            My name is {identity.firstName} and I am a {identity.occupation} at Carfax,
            building front-end experiences that stay clear, fast, and maintainable.
        </p>
        <p>
            Most days I am working in NextJS, helping teams ship dependable
            features while keeping product quality high.
        </p>
        <p>
            My path into software started with freeCodeCamp, and that early
            hands-on learning still shapes how I mentor engineers and approach
            practical problem solving.
        </p>
        <p>
            In my free time, I enjoy {identity.hobbies.join(", ")}.
        </p>
        {happy && <p>I am happy to be learning Astro!</p>}

        {finished && <p>I finished this tutorial!</p>}

        {
            goal === 3 ? (
                <p>My goal is to finish in 3 days.</p>
            ) : (
                <p>My goal is not 3 days.</p>
            )
        }
        <ul class="tags" aria-label="Highlights">
            {skills.map((skill) => <li class="skill">{skill}</li>)}
        </ul>
    </section>
</BaseLayout>
