---
import BaseLayout from "../layouts/BaseLayout.astro";
import type { MarkdownInstance } from "astro";
import type { PostFrontmatter } from "../types/posts";
import BlogBlurb from "../components/BlogBlurb.astro";

const allPosts = Object.values(
    import.meta.glob<MarkdownInstance<PostFrontmatter>>("./posts/*.md", {
        eager: true,
    }),
);
const pageTitle = "Blog";
---
<BaseLayout pageTitle={pageTitle} current="blog">
            <section class="card">
                <p class="eyebrow">Blog</p>
                <p class="lede">
                    Notes on front-end engineering, modern NextJS work, and
                    practical lessons from leading teams.
                </p>
                <p>
                    I keep this page simple while learning Astro. Posts and
                    tutorials will be added here over time.
                </p>
                <ul>
                    {allPosts.map((post: any) => <BlogBlurb url={post.url} title={post.frontmatter.title} description={post.frontmatter.description} publishDate={new Date(post.frontmatter.pubDate)} />)}
                </ul>
            </section>
</BaseLayout>

