---
import Greeting from '../components/Client/Greeter';
import BaseLayout from '../layouts/BaseLayout.astro';
const pageTitle = "Home";
---
<BaseLayout pageTitle={pageTitle} current="home">
  			<section class="card">
				<p class="eyebrow">Home</p>
				
				<p class="lede">
					<Greeting client:load messages={["Hej", "Hallo", "Hola", "Habari"]} />
					Senior software engineer and team lead at Carfax, focused on front-end
					development and modern NextJS apps.
				</p>
				<p>
					Welcome to my personal website. This is where I share a little about my work,
					my background, and what I am learning as I build for the web.
				</p>
			</section>
</BaseLayout>