---
import "../styles/theme.css";
const pageTitle = "JP Sauve | About";

const identity = {
  firstName: "JP",
  country: "Canada",
  occupation: "Senior Software Engineer",
  hobbies: ["cycling", "bikepacking", "learning"],
};

const skills = ["HTML", "CSS", "JavaScript", "React", "Astro", "Writing Docs"];
const happy = true;
const finished = false;
const goal = 3;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
		<meta
			name="description"
			content="About JP Sauve, a senior software engineer and team lead at Carfax focused on front-end development and modern NextJS applications."
		/>
	</head>
	<body>
		<main class="page-wrapper">
			<section class="card">
				<p class="eyebrow">About</p>
				<nav class="nav" aria-label="Main navigation">
					<a href="/">Home</a>
					<a href="/blog">Blog</a>
				</nav>
				<h1>{pageTitle}</h1>
				<p class="lede">
					My name is {identity.firstName} and I am a {identity.occupation} at Carfax, building front-end
					experiences that stay clear, fast, and maintainable.
				</p>
				<p>
					Most days I am working in NextJS, helping teams ship dependable features while
					keeping product quality high.
				</p>
				<p>
					My path into software started with freeCodeCamp, and that early hands-on learning
					still shapes how I mentor engineers and approach practical problem solving.
				</p>
                <p>
					In my free time, I enjoy {identity.hobbies.join(", ")}.
				</p>
                {happy && <p>I am happy to be learning Astro!</p>}

{finished && <p>I finished this tutorial!</p>}

{goal === 3 ? <p>My goal is to finish in 3 days.</p> : <p>My goal is not 3 days.</p>}
				<ul class="tags" aria-label="Highlights">
					<li>Senior Engineer</li>
					<li>Team Lead</li>
					<li>Front-end</li>
					<li>NextJS</li>
				</ul>
			</section>
		</main>
	</body>
</html>